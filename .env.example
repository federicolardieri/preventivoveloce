# Copia questo file in .env.local e inserisci i valori reali
# .env.local NON viene mai committato su git

# ── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Abilita/disabilita i piani a pagamento nell'UI (Starter, Pro).
# Imposta a "true" solo quando Stripe live è attivo e la P.IVA è aperta.
# Se false (default): nei pricing mostriamo solo Free + "In arrivo" sui piani a pagamento.
NEXT_PUBLIC_PAID_PLANS_ENABLED=false

# ── Supabase ─────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_MONTHLY_PRICE_ID=
STRIPE_STARTER_ANNUAL_PRICE_ID=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=

# ── AI (Google AI Studio: https://aistudio.google.com) ──────────
GEMINI_API_KEY=

# ── Email (Resend: https://resend.com) ──────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tuodominio.com

# ── Account deletion webhook (trigger DB → /api/account/on-deleted) ──
# Deve combaciare con `app.account_webhook_secret` configurato nel DB Supabase
ACCOUNT_DELETE_WEBHOOK_SECRET=

# ── Follow-up email webhook (pg_cron → /api/quotes/followup) ──
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FOLLOWUP_WEBHOOK_SECRET=

# ── Cron Health Check ───────────────────────────────────────────
# Segreto per proteggere GET /api/cron/health (genera un UUID casuale)
CRON_HEALTH_SECRET=

# ── Rate Limiting (Upstash: https://upstash.com) ────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Analytics (Plausible: https://plausible.io) ────────────────
# Lascia vuoto per disabilitare analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ── Error Monitoring (Sentry: https://sentry.io) ──────────────
# Lascia vuoto per disabilitare Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
